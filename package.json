{
  "name": "infopunks-trust-layer",
  "version": "1.0.0",
  "description": "x402-gated trust resolution service for Agentic.Market.",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node services/mcp-adapter/src/index.mjs",
    "build": "node scripts/generate-openapi-artifacts.mjs --check && node --check services/mcp-adapter/src/index.mjs && node --check services/mcp-adapter/src/transport/http-server.mjs && node --check scripts/x402-smoke.mjs && node --check scripts/readiness.mjs",
    "start": "node services/mcp-adapter/src/index.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "test": "node --test tests/mcp-adapter-http-health.test.mjs tests/mcp-adapter-listing-readiness.test.mjs tests/mcp-adapter-platform-hardening.test.mjs tests/mcp-adapter-x402.test.mjs tests/mcp-adapter-hardening-sim.test.mjs tests/mcp-adapter-war-room-events.test.mjs",
    "smoke:x402:testnet": "SMOKE_X402_NETWORK=testnet node scripts/x402-smoke.mjs",
    "smoke:x402:mainnet": "SMOKE_X402_NETWORK=mainnet node scripts/x402-smoke.mjs",
    "readiness": "node scripts/readiness.mjs"
  },
  "devDependencies": {
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
