{
  "name": "infopunks-trust-layer",
  "version": "1.0.0",
  "description": "x402-gated trust resolution service for Agentic.Market.",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node services/mcp-adapter/src/index.mjs",
    "build": "node --check services/mcp-adapter/src/index.mjs && node --check services/mcp-adapter/src/transport/http-server.mjs && node --check scripts/lint.mjs && node --check scripts/smoke.mjs && node scripts/openapi-sync.mjs",
    "start": "node services/mcp-adapter/src/index.mjs",
    "lint": "node scripts/lint.mjs",
    "test": "node --test tests/mcp-adapter-http-health.test.mjs tests/mcp-adapter-listing-readiness.test.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:public:testnet": "node scripts/smoke-public.mjs",
    "event-feed": "node scripts/event-feed.mjs --limit 50",
    "proof": "node scripts/proof-artifacts.mjs",
    "proof:public:testnet": "node scripts/proof-public.mjs"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
