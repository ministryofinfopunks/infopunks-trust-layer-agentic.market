{
  "name": "infopunks-trust-layer",
  "version": "1.0.0",
  "description": "Infrastructure-grade trust layer for agent routing.",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/local-up.mjs --fresh",
    "start": "node apps/api/server.mjs",
    "site:dev": "npm run dev -w apps/site",
    "site:build": "npm run build -w apps/site",
    "site:start": "npm run start -w apps/site",
    "local:up": "node scripts/local-up.mjs",
    "clean": "node scripts/clean.mjs",
    "build": "npm run site:build && npm run contract:generate -- --check",
    "contract:generate": "node scripts/generate-openapi-artifacts.mjs",
    "sim:demo": "node apps/simulator/run.mjs",
    "test": "node --test tests/*.test.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "speccheck": "node scripts/generate-openapi-artifacts.mjs --check && node scripts/speccheck.mjs",
    "ci": "npm run lint && npm run typecheck && npm test && npm run speccheck",
    "seed": "node scripts/seed/seed-demo.mjs",
    "replay": "node scripts/replay/replay-trace.mjs",
    "mcp:adapter": "node services/mcp-adapter/src/index.mjs"
  },
  "devDependencies": {
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
