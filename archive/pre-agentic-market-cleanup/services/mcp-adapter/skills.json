{
  "schema": "infopunks.agentic.skill.v1",
  "service": {
    "name": "Infopunks Trust Score",
    "endpoint": "https://mcp.infopunks.ai/mcp",
    "tags": ["trust-routing", "agent-security", "x402", "mcp", "risk-pricing"]
  },
  "skills": [
    {
      "name": "get_passport",
      "tool": "get_passport",
      "description": "Fetch Passport identity/capability metadata before trust or routing calls.",
      "input": {
        "subject_id": "agent_221"
      }
    },
    {
      "name": "resolve_trust",
      "tool": "resolve_trust",
      "description": "Resolve trust for an acting agent using deterministic compact output.",
      "input": {
        "subject_id": "agent_221",
        "agent": { "agent_id": "router_alpha", "did": "did:agentic:router_alpha" },
        "context": { "task_type": "route_execution", "domain": "defi", "risk_level": "high" },
        "candidate_validators": ["validator_a", "validator_b"],
        "payment": { "rail": "x402", "payer": "router_alpha", "units_authorized": 1, "nonce": "n1" }
      }
    },
    {
      "name": "select_validators",
      "tool": "select_validators",
      "description": "Select validators for quorum-safe validation routing.",
      "input": {
        "agent": { "agent_id": "router_alpha" },
        "subject_id": "agent_221",
        "task_id": "task_9001",
        "candidates": ["validator_a", "validator_b", "validator_c"],
        "context": { "task_type": "validation", "domain": "defi", "risk_level": "high" },
        "payment": { "rail": "x402", "payer": "router_alpha", "units_authorized": 2, "nonce": "n2" }
      }
    },
    {
      "name": "select_executor",
      "tool": "select_executor",
      "description": "Select execution candidates under trust and cost constraints.",
      "input": {
        "subject_id": "agent_221",
        "task_id": "task_9001",
        "candidates": ["service_a", "service_b"],
        "context": { "task_type": "payment_execution", "domain": "payments", "risk_level": "high" },
        "maximum_cost_usd": 5,
        "allow_autonomy_downgrade": true,
        "payment": { "rail": "x402", "payer": "router_alpha", "units_authorized": 2, "nonce": "n3" }
      }
    },
    {
      "name": "evaluate_dispute",
      "tool": "evaluate_dispute",
      "description": "Resolve conflicting evidence or validator disagreement.",
      "input": {
        "subject_id": "agent_221",
        "task_id": "task_7781",
        "evidence_ids": ["ev_1", "ev_2"],
        "context": { "task_type": "market_analysis", "domain": "crypto", "risk_level": "high" },
        "reason_code": "conflicting_validation",
        "severity": "high",
        "payment": { "rail": "x402", "payer": "router_alpha", "units_authorized": 3, "nonce": "n4" }
      }
    },
    {
      "name": "quote_risk",
      "tool": "quote_risk",
      "description": "Request a paid risk quote for a trust context.",
      "input": {
        "subject_id": "agent_221",
        "agent": { "agent_id": "router_alpha" },
        "context": { "task_type": "capital_allocation", "domain": "defi", "risk_level": "high" },
        "exposure_usd": 50000,
        "payment": { "rail": "x402", "payer": "router_alpha", "units_authorized": 2, "nonce": "n5" }
      }
    }
  ]
}
